def clean_line_text(text):
    """Strips out LaTeX commands to get clean plain text for matching."""
    text = re.sub(r"\\[a-zA-Z]+\*?\{", "", text) # Remove macros like \section{ or \textbf{
    text = text.replace("}", "")
    text = re.sub(r"[^\w\s]", "", text) # Clear punctuation/symbols
    return text.lower().strip()

def fuzzy_clear_slicer(input_file, output_dir="sections"):
    if not os.path.exists(input_file):
        print(f"🚨 Error: Missing '{input_file}' in active workspace.")
        return

    os.makedirs(output_dir, exist_ok=True)
    
    print(f"📖 Scanning document lines for fuzzy title intersections...")
    with open(input_file, "r", encoding="utf-8") as f:
        lines = f.readlines()

    # Track structural split markers
    positions = []
    current_char_count = 0
    
    # Pre-compile full string for character indexing extraction downstream
    with open(input_file, "r", encoding="utf-8") as f:
        full_text = f.read()

    for idx, line in enumerate(lines):
        line_len = len(line)
        cleaned = clean_line_text(line)
        
        # Check if any subsection keyword hits inside the sanitized line string
        for title in SUBSECTIONS:
            clean_title = re.sub(r"[^\w\s]", "", title).lower().strip()
            # Guardrail: Ensure it matches the core phrase, but ignore formatting wrappers
            if clean_title in cleaned and len(cleaned) < len(clean_title) + 20:
                positions.append((current_char_count, title))
                break
                
        current_char_count += line_len

    # Sort positions chronologically top-to-bottom
    positions.sort(key=lambda x: x[0])
    
    # Filter out duplicate hits close together on the same line
    filtered_positions = []
    last_pos = -1
    for pos, title in positions:
        if pos > last_pos + 10:
            filtered_positions.append((pos, title))
            last_pos = pos

    if not filtered_positions:
        print("❌ Fuzzy match failed. The document structure might be entirely flat paragraphs.")
        return

    print(f"🧩 Mapped {len(filtered_positions)} clean break nodes. Cutting sections...")
    
    counts = {}
    for i, (start_pos, title) in enumerate(filtered_positions):
        clean_name = re.sub(r"[^\w]", "_", title.lower()).strip("_")
        clean_name = re.sub(r"__+", "_", clean_name)
        
        counts[clean_name] = counts.get(clean_name, 0) + 1
        suffix = f"_{counts[clean_name]}" if counts[clean_name] > 1 else ""
        
        filename = f"{i+1:02d}_{clean_name}{suffix}.tex"
        filepath = os.path.join(output_dir, filename)
        
        end_pos = filtered_positions[i + 1][0] if i + 1 < len(filtered_positions) else len(full_text)
        chunk = full_text[start_pos:end_pos].strip()
        
        with open(filepath, "w", encoding="utf-8") as out_f:
            out_f.write(chunk)
            
    print(f"\n✨ Generation Successful! Your text chunks are waiting inside: '{output_dir}/'")

if __name__ == "__main__":
    fuzzy_clear_slicer("document_content.tex")